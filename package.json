{
  "name": "jalaali-js",
  "version": "2.0.0",
  "description": "Converts Gregorian and Jalaali calendars to each other",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalaali/jalaali-js.git"
  },
  "keywords": [
    "jalaali",
    "jalali",
    "persian",
    "khorshidi",
    "shamsi",
    "calendar",
    "date",
    "typescript",
    "esm"
  ],
  "author": "Behrang Noruzi Niya",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jalaali/jalaali-js/issues"
  },
  "homepage": "https://github.com/jalaali/jalaali-js",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:package": "publint --strict",
    "bench": "tsx bench/bench.ts",
    "prepublishOnly": "pnpm typecheck && pnpm build && pnpm test && pnpm lint:package"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.1.0",
    "publint": "^0.3.21",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
